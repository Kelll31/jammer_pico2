{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Pico Debug (Cortex-Debug)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${command:cmake.launchTargetPath}",
            "servertype": "openocd",
            "serverpath": "openocd",
            "gdbPath": "riscv32-unknown-elf-gdb",
            "toolchainPrefix": "riscv32-unknown-elf",
            "device": "RP2350",
            "searchDir": [
                "${userHome}/.pico-sdk/openocd/0.12.0+dev/scripts"
            ],
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/rp2350.cfg"
            ],
            "svdFile": "${userHome}/.pico-sdk/sdk/2.2.0/src/rp2350/hardware_regs/rp2350.svd",
            "runToEntryPoint": "main",
            "postRestartCommands": [
                "break main",
                "continue"
            ],
            "openOCDLaunchCommands": [
                "adapter speed 5000"
            ]
        },
        {
            "name": "Pico Debug (External OpenOCD)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${command:cmake.launchTargetPath}",
            "servertype": "external",
            "gdbTarget": "localhost:3333",
            "gdbPath": "riscv32-unknown-elf-gdb",
            "device": "RP2350",
            "runToEntryPoint": "main"
        }
    ]
}